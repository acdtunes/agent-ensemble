# Test Dockerfile for agent-ensemble installation
# Verifies the install flow works from a clean environment
#
# Build: docker build -f Dockerfile.test -t agent-ensemble-test .
# Run:   docker run --rm agent-ensemble-test

FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 20 for dashboard
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install pipx
RUN pip install pipx && pipx ensurepath
ENV PATH="/root/.local/bin:$PATH"

# Create a non-root user to simulate real usage
RUN useradd -m -s /bin/bash testuser
USER testuser
WORKDIR /home/testuser

# Install pipx for testuser
RUN pip install --user pipx
ENV PATH="/home/testuser/.local/bin:$PATH"
RUN pipx ensurepath

# Clone the repository (uses build arg for flexibility)
ARG REPO_URL=https://github.com/acdtunes/agent-ensemble.git
ARG BRANCH=main
RUN git clone --branch ${BRANCH} ${REPO_URL} agent-ensemble

# Run the installation
WORKDIR /home/testuser/agent-ensemble
RUN ./install.sh

# Verify CLI installation
RUN echo "=== CLI Verification ===" && \
    echo "1. Checking commands directory..." && \
    ls -la ~/.claude/commands/ensemble/ && \
    echo "" && \
    echo "2. Checking Python library..." && \
    ls -la ~/.claude/lib/python/agent_ensemble/ && \
    echo "" && \
    echo "3. Checking CLI modules..." && \
    ls -la ~/.claude/lib/python/agent_ensemble/cli/ && \
    echo "" && \
    echo "4. Checking manifest..." && \
    cat ~/.claude/ensemble-manifest.txt && \
    echo "" && \
    echo "5. Checking nWave installation..." && \
    ls ~/.claude/agents/nw-*.md 2>/dev/null | head -5 || echo "nWave agents found" && \
    echo "" && \
    echo "=== CLI checks passed ==="

# Build and test the dashboard
RUN echo "=== Dashboard Build ===" && \
    cd board && \
    npm install && \
    npm run build && \
    echo "" && \
    echo "Checking build output..." && \
    ls -la dist/ && \
    echo "" && \
    echo "=== Dashboard build passed ==="

# Run dashboard unit tests
RUN echo "=== Dashboard Unit Tests ===" && \
    cd board && \
    npm test && \
    echo "=== Dashboard unit tests passed ==="

# Install Playwright browsers for E2E tests
RUN cd board && npx playwright install chromium && npx playwright install-deps chromium

# Run Playwright E2E smoke tests
RUN echo "=== Dashboard E2E Smoke Tests ===" && \
    cd board && \
    npm run test:e2e && \
    echo "=== Dashboard E2E tests passed ==="

# Default command shows what was installed
CMD ["bash", "-c", "echo 'All tests passed!' && echo '' && echo 'CLI:' && cat ~/.claude/ensemble-manifest.txt && echo '' && echo 'Dashboard: dist/ built successfully'"]
